# Local code-signing config. Copy to .env (gitignored) and edit.
# Uncomment and set the thumbprint of a code-signing cert in your cert store.

# OPENTDB_CODESIGN_THUMBPRINT=757D7602DBB904AAAD87E82701738596DD8DB28A

# CI uses these instead. Do NOT commit a real PFX or password.
# OPENTDB_CODESIGN_PFX_B64=...
# OPENTDB_CODESIGN_PASSWORD=...
