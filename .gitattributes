# Auto-detect text files and normalize line endings to LF in the repo.
* text=auto eol=lf

# Force Windows-native line endings for files that tooling expects CRLF.
*.bat        text eol=crlf
*.cmd        text eol=crlf
*.ps1        text eol=crlf
*.sln        text eol=crlf

# C# / .NET source - always LF in repo, normalized on checkout per platform.
*.cs         text diff=csharp
*.csproj     text
*.props      text
*.targets    text
*.axaml      text
*.xaml       text
*.json       text
*.yml        text
*.yaml       text
*.md         text

# Binaries - never normalize.
*.png        binary
*.jpg        binary
*.ico        binary
*.pfx        binary
*.snk        binary
*.dll        binary
*.exe        binary
