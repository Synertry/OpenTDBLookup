# --- Build output ---
[Bb]in/
[Oo]bj/
[Oo]ut/
[Ll]og/
[Ll]ogs/
publish/

# --- Visual Studio / Rider / VS Code ---
.vs/
.idea/
.vscode/
*.user
*.suo
*.userprefs
*.cache
*.swp
# NuGet packages.lock.json files MUST be committed - CI uses them for
# the cache key + dotnet restore --locked-mode. Older .NET tooling
# bundled them under `*.lock.json` ignores; modern tooling keeps them.
!**/packages.lock.json

# --- ReSharper / Resharper ---
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# --- TestResults / coverage ---
[Tt]est[Rr]esult*/
*.coverage
*.coveragexml
coverage*.json
coverage*.xml
*.lcov

# --- NuGet ---
*.nupkg
*.snupkg
.nuget/
packages/
project.lock.json
project.fragment.lock.json
artifacts/

# --- App-specific runtime data (NEVER commit user-generated cache) ---
questions.json
questions.json.tmp
settings.json

# --- OS junk ---
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
.DS_Store
.AppleDouble
.LSOverride

# --- Misc ---
*.log
*.pid
*.tmp
*.bak
*.orig

# --- Code-signing material (must never be checked in) ---
*.pfx
*.p12
*.snk

# --- Local environment overrides for the signing script and similar ---
.env
.env.local

# --- Personal notes (kept local; never published) ---
notes/
