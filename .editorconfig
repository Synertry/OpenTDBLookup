root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{json,yml,yaml,axaml,xaml,xml,csproj,props,targets}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.cs]
indent_size = 4
csharp_using_directive_placement = outside_namespace:warning
csharp_style_namespace_declarations = file_scoped:warning
csharp_prefer_braces = true:warning
csharp_style_expression_bodied_methods = when_on_single_line:silent
csharp_style_expression_bodied_constructors = false:silent
csharp_style_expression_bodied_properties = when_on_single_line:silent
csharp_style_var_when_type_is_apparent = true:warning
csharp_style_var_for_built_in_types = false:warning
csharp_style_var_elsewhere = false:silent

# Nullability and modern features
# Note: dotnet_style_require_accessibility_modifiers is intentionally NOT set
# here. IDE0040 is silenced below because interface members idiomatically omit
# accessibility modifiers; setting the style rule would just be dead config.
dotnet_diagnostic.CS8618.severity = warning
dotnet_diagnostic.CS8625.severity = warning

# Unused usings
dotnet_diagnostic.IDE0005.severity = warning

# House-style overrides for analyzer noise that fights the established codebase:
# IDE0008  - "use explicit type instead of var" - the codebase uses var throughout.
# CA1848   - "use LoggerMessage delegates" - perf micro-opt, not worth the indirection here.
# CA1873   - "avoid potentially expensive logging" - same family as CA1848.
# CA1859   - "change return type to concrete type" - design choice, kept interface returns.
dotnet_diagnostic.IDE0008.severity = silent
dotnet_diagnostic.CA1848.severity = none
dotnet_diagnostic.CA1873.severity = none
dotnet_diagnostic.CA1859.severity = none

# IDE0040 - "accessibility modifier required" fires on every interface member;
#           non-idiomatic to write `public` on interface methods. Silence.
# CA1305   - locale-aware ToString. English-only app per README "Out of scope".
# CA1716   - "name conflicts with VB.NET reserved keyword". VB.NET is dead.
dotnet_diagnostic.IDE0040.severity = silent
dotnet_diagnostic.CA1305.severity = none
dotnet_diagnostic.CA1716.severity = none

# Test project: snake_case test names are the house style. CA1707 fights it.
# Glob uses single-level `*` per the editorconfig spec; works for files in
# OpenTDBLookup.Tests/ regardless of subdir depth because the project layout
# keeps all *Tests.cs at the test project root.
[*Tests*.cs]
dotnet_diagnostic.CA1707.severity = none
